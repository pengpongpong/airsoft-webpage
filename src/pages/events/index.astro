---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sanityClient } from 'sanity:client';
import SanityImage from '../../components/SanityImage.astro';

const events = await sanityClient
  .fetch(`*[_type == "event"] | order(eventDate desc){
    _id,
    title,
    slug,
    eventDate,
    location,
    description,
    image
  }`)
  .catch(() => []);
---

<BaseLayout
  title="Events | Airsoft Club"
  description="Kommende Spiele und Events"
  currentPage="/events"
>
  <section class="page-hero">
    <div class="container">
      <h1>Events</h1>
      <p class="page-subtitle">Kommende Spiele und Veranstaltungen</p>
    </div>
  </section>

  <section class="events-section">
    <div class="container">
      {events.length > 0 ? (
        <div class="events-grid">
          {events.map((event) => (
            <a
              href={`/events/${event.slug?.current ?? event._id}`}
              class="event-card"
            >
              {event.image?.asset ? (
                <div class="event-card-image">
                  <SanityImage
                    asset={event.image}
                    alt={event.title}
                    width={560}
                  />
                </div>
              ) : (
                <div class="event-card-placeholder"></div>
              )}
              <div class="event-card-content">
                <h3 class="event-title">{event.title}</h3>
                {event.eventDate ? (
                  <time class="event-date" datetime={event.eventDate}>
                    {new Date(event.eventDate).toLocaleDateString('de-DE', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                      hour: '2-digit',
                      minute: '2-digit',
                    })}
                  </time>
                ) : null}
                {event.location ? (
                  <span class="event-location">{event.location}</span>
                ) : null}
                {event.description ? (
                  <p class="event-description">{event.description}</p>
                ) : null}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <p>Noch keine Events.</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: 3rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .page-hero h1 {
    margin: 0 0 0.5rem;
    font-size: 2.5rem;
  }

  .page-subtitle {
    margin: 0;
    color: var(--color-text-muted);
  }

  .events-section {
    padding: 3rem 0;
  }

  .events-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .event-card {
    display: block;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: all var(--transition);
  }

  .event-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }

  .event-card-placeholder {
    aspect-ratio: 16/10;
    background: var(--color-surface-hover);
  }

  .event-card-image {
    aspect-ratio: 16/10;
    overflow: hidden;
  }

  .event-card-image :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .event-card-content {
    padding: 1.25rem;
  }

  .event-title {
    margin: 0 0 0.5rem;
    font-size: 1.25rem;
  }

  .event-date,
  .event-location {
    display: block;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .event-description {
    margin: 0.5rem 0 0;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .empty-state {
    text-align: center;
    padding: 3rem 0;
  }

  .empty-state p {
    margin: 0 0 1rem;
    color: var(--color-text-muted);
  }
</style>
