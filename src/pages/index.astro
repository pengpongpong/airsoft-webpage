---
import BaseLayout from '../layouts/BaseLayout.astro';
import { sanityClient } from 'sanity:client';
import SanityImage from '../components/SanityImage.astro';

const siteInfo = await sanityClient
  .fetch(`*[_type == "siteInfo"][0]{
    clubName,
    tagline,
    heroImage
  }`)
  .catch(() => null);

const clubName = siteInfo?.clubName ?? 'Airsoft Club';
const tagline = siteInfo?.tagline ?? 'Taktische Sportgemeinschaft';
const heroImage = siteInfo?.heroImage;
---

<BaseLayout title={clubName} description={tagline} currentPage="/">
  <section class="hero">
    {heroImage?.asset ? (
      <div class="hero-image-wrap">
        <SanityImage
          asset={heroImage}
          alt={clubName}
          class="hero-image"
          width={800}
        />
      </div>
    ) : (
      <div class="hero-placeholder"></div>
    )}
    <div class="hero-content">
      <h1 class="hero-title">{clubName}</h1>
      <p class="hero-tagline">{tagline}</p>
      <div class="hero-actions">
        <a href="/info" class="btn btn-primary">Spiel-Info</a>
        <a href="/photos" class="btn btn-secondary">Photoalbum</a>
      </div>
    </div>
  </section>

  <section class="intro">
    <div class="container">
      <h2>Willkommen</h2>
      <p class="intro-text">
        Werde Teil unserer Gemeinschaft von Taktiksport-Enthusiasten. Wir veranstalten regelmäßige Spiele,
        halten sichere Spielstandards ein und heißen sowohl Einsteiger als auch erfahrene Spieler willkommen.
      </p>
      <div class="intro-links">
        <a href="/about" class="link-card">
          <span class="link-card-title">Über uns</span>
          <span class="link-card-desc">Erfahre mehr über unseren Verein und unsere Mission</span>
        </a>
        <a href="/contact" class="link-card">
          <span class="link-card-title">Kontakt</span>
          <span class="link-card-desc">Nimm Kontakt auf oder werde Teil unserer Gemeinschaft</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    display: flex;
    flex-direction: column;
  }

  .hero-image-wrap {
    width: 100%;
    padding: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .hero-image {
    max-width: 400px;
    max-height: 120px;
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
  }

  .hero-placeholder {
    width: 100%;
    aspect-ratio: 21 / 9;
    background: linear-gradient(135deg, var(--color-surface) 0%, var(--color-bg) 100%);
    flex-shrink: 0;
  }

  .hero-content {
    text-align: center;
    padding: 2rem;
  }

  .hero-title {
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    margin: 0 0 0.5rem;
    letter-spacing: 0.2em;
  }

  .hero-tagline {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    margin: 0 0 2rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-radius: var(--radius);
    transition: all var(--transition);
  }

  .btn-primary {
    background: var(--color-accent);
    color: white;
    border: 2px solid var(--color-accent);
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
    border-color: var(--color-accent-hover);
    color: white;
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-text);
    border: 2px solid var(--color-border);
  }

  .btn-secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .intro {
    padding: 4rem 0;
  }

  .intro h2 {
    margin: 0 0 1rem;
    font-size: 2rem;
  }

  .intro-text {
    max-width: 600px;
    margin: 0 0 2rem;
    color: var(--color-text-muted);
  }

  .intro-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
  }

  .link-card {
    display: block;
    padding: 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    transition: all var(--transition);
  }

  .link-card:hover {
    border-color: var(--color-accent);
    background: var(--color-surface-hover);
  }

  .link-card-title {
    display: block;
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .link-card-desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
  </style>
