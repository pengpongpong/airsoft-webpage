---
import BaseLayout from '../layouts/BaseLayout.astro';
import {sanityClient} from 'sanity:client';
import SanityImage from '../components/SanityImage.astro';

const siteInfo = await sanityClient
    .fetch(`*[_type == "siteInfo"][0]{
    clubName,
    tagline,
    heroImage
  }`)
    .catch(() => null);

const clubName = siteInfo?.clubName ?? 'Airsoft Panthers Graz';
---

<BaseLayout title={clubName} currentPage="/">
    <section class="hero">
        <img class="hero-img" src="/svg/LandingPage_Photo_freigestellt.svg" alt="logo"/>
        <div class="hero-content">
            <h1 class="hero-title">{clubName}</h1>
            <div class="hero-btn-container">
                <a href="/contact" class="hero-btn">COOL, I'M WITH YOU!</a>
                <div class="hero-socials">
                    Social Media
                    <div>
                        <a href="https://www.facebook.com/AirsoftPanthersGraz/" rel="noopener noreferrer" target="_blank">
                            <i class="fa-brands fa-facebook"></i>
                        </a>
                        <a href="https://www.youtube.com/@AirsoftPanthersGraz" rel="noopener noreferrer" target="_blank">
                            <i class="fa-brands fa-youtube"></i>
                        </a>
                        <a href="https://www.instagram.com/airsoft_panthers_graz" rel="noopener noreferrer" target="_blank">
                            <i class="fa-brands fa-instagram"></i>
                        </a>
                        <a href="https://t.me/+RPahXTngC-tch6rs?utm_source=ig&utm_medium=social&utm_content=link_in_bio#" rel="noopener noreferrer" target="_blank">
                            <i class="fa-brands fa-telegram"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

</BaseLayout>

<style>
    .hero {
        position: relative;
    }

    .hero-content {
        margin-left: 27rem;
        padding: 2rem;
    }

    .hero-title {
        font-size: 10rem;
        margin: 0 0 0.5rem;
        letter-spacing: -.1em;
        line-height: 10rem;
        font-weight: bold;
    }

    .hero-btn-container {
        padding-right: 10rem;
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: flex-end;
    }

    .hero-img {
        width: auto;
        height: 80vh;
        position: absolute;
        top: -6rem;
        left: 0;
    }

    .hero-socials {
        display: flex;
        gap: .5rem;
        margin-top: 2rem;
        color: #909090;
        font-weight: bold;

        i {
            color: #909090;
        }

        & > div {
            width: fit-content;
            display: flex;
            gap: .25rem;
        }
    }

    .hero-btn {
        width: fit-content;
        padding: 1.5rem 3rem;
        text-align: center;
        border: none;
        border-radius: var(--radius);
        background-color: #e34234;
        background-image: linear-gradient(315deg, #e34234 0%, #ff3800 74%);
        text-transform: uppercase;
        color: #fff;
        font-weight: bold;
        font-size: 1.75rem;
        cursor: pointer;
        letter-spacing: 1px;

        box-shadow: /* Neon glow (outer red) */ 0 0 20px #ff0000,
        0 0 40px #ff0000,
            /* 3D bevel: darker red sides for depth */ 0 4px 0 #cc0000,
        0 6px 0 #aa0000,
            /* Bottom drop shadow for height illusion */ 0 8px 20px rgba(0, 0, 0, 0.5),
            /* Inner shine */ inset 0 0 20px rgba(255, 255, 255, 0.2);
        text-shadow: 0 0 10px rgba(255, 255, 255, 0.8);
        //transition: all 0.3s ease;
        position: relative;
        transition: transform 0.1s ease, box-shadow 0.1s ease;
    }

    .hero-btn:hover {
        transform: translateY(2px);
        box-shadow: /* Glow intensifies */ 0 0 30px #ff0000,
        0 0 60px #ff0000,
            /* Slightly compressed bevel (starts pressing) */ 0 2px 0 #cc0000,
        0 4px 0 #aa0000,
            /* Reduced drop shadow (sinking) */ 0 5px 15px rgba(0, 0, 0, 0.6),
        inset 0 0 30px rgba(255, 255, 255, 0.3);
    }

    .hero-btn:active {
        box-shadow: /* Glow dims slightly on full press */ 0 0 15px #ff0000,
            /* Flattened bevel (pressed down) */ 0 0 0 #cc0000,
        0 0 0 #aa0000,
            /* Minimal bottom shadow */ 0 2px 8px rgba(0, 0, 0, 0.7),
            /* Stronger inset for concave feel */ inset 0 2px 15px rgba(0, 0, 0, 0.2),
        inset 0 0 30px rgba(255, 255, 255, 0.1);
        transform: translateY(6px); /* Full press sink */
        transition: all 0.1s ease; /* Snappy feedback */
    }

    .btn {
        display: inline-block;
        padding: 0.75rem 1.5rem;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        border-radius: var(--radius);
        transition: all var(--transition);
    }

    .btn-primary {
        background: var(--color-accent);
        color: white;
        border: 2px solid var(--color-accent);
    }

    .btn-primary:hover {
        background: var(--color-accent-hover);
        border-color: var(--color-accent-hover);
        color: white;
    }

    .btn-secondary {
        background: transparent;
        color: var(--color-text);
        border: 2px solid var(--color-border);
    }

    .btn-secondary:hover {
        border-color: var(--color-accent);
        color: var(--color-accent);
    }
</style>
